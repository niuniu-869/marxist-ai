    {
      "n": 4,
      "original_html": "亲爱的公民：",
      "original_plain": "亲爱的公民：",
      "gist": null,
      "plain_rewrite": null,
      "block_type": "author_text",
      "length_policy": "normal_paragraph",
      "sentences": [
        {
          "sid": "p4s1",
          "original": "亲爱的公民：",
          "char_start": 0,
          "char_end": 6,
          "plain": null,
          "speaker": null,
          "stance": null,
          "notes": []
        }
