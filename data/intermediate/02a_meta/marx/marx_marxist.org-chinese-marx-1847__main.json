        "target_type": "person",
        "target_id": "proudhon",
        "target_name_zh": "蒲鲁东",
        "view_being_refuted": "认为提高工资的罢工会导致生活必需品价格普遍上涨和匮乏，因此反对工人组织同盟和罢工。",
        "author_position": "马克思认为蒲鲁东的经济学观点是错误的，罢工和同盟是工人阶级斗争的必要形式，并具有政治意义。"
      }
